DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
JWT_SECRET="replace_with_a_long_random_secret"
SESSION_SECRET="replace_with_another_long_random_secret_for_token_encryption"
PORT=5000
FRONTEND_URL="http://localhost:5173"

# Google OAuth demo/testing credentials.
# Configure this redirect URI in Google Cloud Console:
# http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/auth/google/callback"

# Keep this small for demo/privacy. The scanner searches likely subscription emails only.
GMAIL_SCAN_LIMIT=150

# Renewal reminder email job. Without SMTP config, reminders are logged for demo.
ENABLE_RENEWAL_EMAILS=true
RENEWAL_REMINDER_DAYS=3
RENEWAL_REMINDER_INTERVAL_MS=21600000
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
EMAIL_FROM="SubTracker <your_email@gmail.com>"

# Optional AI key already used by the existing project.
OPENROUTER_API_KEY="your_openrouter_api_key"
